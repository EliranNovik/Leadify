# Pelecard Gateway 2.0 (server-side only — never expose to frontend)

# --- Production terminal (live charges) ---
PELECARD_BASE_URL=https://gateway20.pelecard.biz
PELECARD_TERMINAL=your_production_terminal_number
PELECARD_USER=your_production_api_user
PELECARD_PASSWORD=your_production_api_password

# --- Sandbox / test terminal (only for https://rainmakerqueen.onrender.com) ---
# All other frontends (rainmakerqueen.org, localhost, etc.) use production credentials above.
# PELECARD_SANDBOX_TERMINAL=your_test_terminal_number
# PELECARD_SANDBOX_USER=your_test_api_user
# PELECARD_SANDBOX_PASSWORD=your_test_api_password
# Optional overrides (defaults: render.com staging only):
# PELECARD_SANDBOX_APP_PUBLIC_URL=https://rainmakerqueen.onrender.com
# PELECARD_SANDBOX_FRONTEND_ORIGINS=https://rainmakerqueen.onrender.com

# Legacy flag: adds QAResultStatus=000 on the *production* terminal only (not needed when using PELECARD_SANDBOX_* credentials)
# PELECARD_SANDBOX=true
# PELECARD_ENV=sandbox

# Where users land after payment (frontend)
APP_PUBLIC_URL=https://rainmakerqueen.org

# Public URL of THIS backend (Pelecard GoodURL/ErrorURL/CancelURL callbacks)
BACKEND_PUBLIC_URL=https://leadify-crm-backend.onrender.com

# Checkout iframe theme (recommended — uses Pelecard portal “Select CSS” variants)
# English checkout: variants 1 or 4 (4 = modern teal layout). Hebrew: 1–4.
PELECARD_CSS_VARIANT=4
PELECARD_CHECKOUT_LANGUAGE=en

# Installments (tashlumim) — default single payment; MinPayments=1 prevents "0" / NaN breakdown in iframe
# PELECARD_MIN_PAYMENTS=1
# PELECARD_MAX_PAYMENTS=1
# PELECARD_FIRST_PAYMENT=auto
# To allow up to 12 installments: PELECARD_MAX_PAYMENTS=12

# Optional: fully custom CSS (external URL — Pelecard must whitelist your domain; often ignored)
# Uncomment only if Pelecard enabled external CssURL for your terminal:
# PELECARD_CSS_URL=https://rainmakerqueen.onrender.com/pelecard-checkout.css
# PELECARD_CSS_VERSION=10

# Optional small logo in iframe header (omit to hide logo; also set TopText empty)
# PELECARD_LOGO_URL=https://rainmakerqueen.onrender.com/RMQ_LOGO.png
# PELECARD_TOP_TEXT=
# Apple Pay / Google Pay: enable on your Pelecard terminal (merchant portal). Buttons show inside the iframe when supported.
# CustomerIdField (Id/SSN/Passport) is required in checkout; EmailField is hidden — see buildCheckoutDisplayOptions in pelecardService.js

# Automated payment confirmation email (misc_emailtemplate id 184)
# Supabase auth user id of a staff account with a connected Microsoft mailbox (Graph Mail.Send)
PAYMENT_CONFIRMATION_MAILBOX_USER_ID=your_supabase_user_uuid

# Client self-scheduling booking (Teams calendar + confirmation email via delegated Graph)
# Staff user with connected mailbox that has delegate access to shared-potentialclients@ / shared-newclients@
BOOKING_MAILBOX_USER_ID=your_supabase_user_uuid
# Staff employee id for WhatsApp template Mobile/Phone/Email (default 1; overridden by meeting manager in global settings)
BOOKING_WHATSAPP_EMPLOYEE_ID=1
# Optional override (default 184)
# PAYMENT_CONFIRMATION_EMAIL_TEMPLATE_ID=184

# Payper tax invoice-receipt (CreatePayperInvoice via Pelecard Gateway)
# Requires Payper enabled on your Pelecard terminal — confirm with Pelecard support.
ENABLE_PAYPER_INVOICE=true
PELECARD_PAYPER_INVOICE_PATH=services/CreatePayperInvoice
PAYPER_INCOME_ID=-100000000
# Your Payper income type id (sample uses -100000000; set to your value from Payper UI if different)
# PAYPER_INCOME_ID=599
PAYPER_SEND_BY_MAIL=true
# Same amount on invoice + receipt; include_vat "true" per Pelecard sample
PAYPER_INCLUDE_VAT=true
# PAYPER_DOCUMENT_NO_VAT=false
# PAYPER_DOCUMENT_ROUNDED=false
# Reconcile only null/pending Payper status (not failed — use Finances ↻ or POST create-payper-invoice)
# PAYPER_RECONCILE_BATCH_SIZE=20
# PAYPER_RECONCILE_LOOKBACK_HOURS=168

# Payment reconciliation (recovers Pelecard charges when DB write failed)
# ENABLE_PELECARD_RECONCILE_SCHEDULER=true
# PELECARD_RECONCILE_TICK_MS=300000
# PELECARD_RECONCILE_STARTUP_DELAY_MS=45000
# PELECARD_RECONCILE_LOOKBACK_HOURS=168
# PELECARD_RECONCILE_BATCH_SIZE=40
# PELECARD_DB_RETRY_ATTEMPTS=3
# PELECARD_DB_RETRY_DELAY_MS=300
